{
  "name": "joborbit",
  "private": true,
  "version": "1.0.0",

  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules"
  },

  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "^5.9.2",
    "rimraf": "^5.0.5"
  },

  "workspaces": [
    "apps/*",
    "packages/*"
  ],

  "engines": {
    "node": ">=18"
  },

  "packageManager": "npm@10.9.2"
}